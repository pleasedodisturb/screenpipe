{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/page.tsx",
    "app/**/layout.tsx",
    "app/**/not-found.tsx",
    "app/**/error.tsx",
    "e2e/specs/**/*.spec.ts",
    "e2e/tests/**/*.js",
    "e2e/helpers/**/*.ts",
    "scripts/**/*.js"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "scripts/**/*.{ts,js}",
    "e2e/**/*.{ts,js}"
  ],
  "ignore": [
    "**/__tests__/**",
    "**/*.test.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "ts-node",
    "mocha",
    "@wdio/cli",
    "@wdio/local-runner",
    "@wdio/globals"
  ],
  "next": true,
  "tailwind": true,
  "postcss": true,
  "vitest": true,
  "webdriver-io": {
    "config": "e2e/wdio.conf.ts"
  }
}
